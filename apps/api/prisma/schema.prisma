// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  moduleFormat    = "cjs"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

enum AccessContext {
  platform
  organization
}

enum OrganizationType {
  workspace
}

enum MembershipStatus {
  invited
  active
  suspended
}

enum SubscriptionStatus {
  trialing
  active
  expired
  canceled
}

enum DiscountType {
  fixed
  percent
}

enum TransactionStatus {
  pending
  completed
  failed
  refunded
}

enum PaymentMethod {
  manual
  bank_transfer
  other
}

enum PlanInterval {
  monthly
  yearly
  weekly
}

enum InvoiceStatus {
  draft
  sent
  paid
  voided
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  name            String?
  passwordHash    String?   @map("password_hash")
  isPlatformOwner Boolean   @default(false) @map("is_platform_owner")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  organizationMemberships OrganizationMembership[] @relation("MembershipUser")
  membershipsInvited      OrganizationMembership[] @relation("MembershipInvitedBy")
  userRoles               UserRole[]               @relation("UserRoleUser")
  userRolesAssignedBy     UserRole[]               @relation("UserRoleAssignedBy")
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]

  @@map("users")
}

model RefreshToken {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  tokenHash     String        @unique @map("token_hash")
  accessContext AccessContext @map("access_context")
  expiresAt     DateTime      @map("expires_at")
  revokedAt     DateTime?     @map("revoked_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  ipAddress     String?       @map("ip_address") @db.VarChar(64)
  userAgent     String?       @map("user_agent") @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  type      OrganizationType
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  memberships  OrganizationMembership[]
  roles        Role[]
  userRoles    UserRole[]
  subscriptions Subscription[]
  invoices     Invoice[]
  transactions Transaction[]

  @@map("organizations")
}

model OrganizationMembership {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  isOwner        Boolean          @default(false) @map("is_owner")
  status         MembershipStatus
  invitedBy      String?          @map("invited_by") @db.Uuid
  invitedAt      DateTime?        @map("invited_at")
  joinedAt       DateTime?        @map("joined_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  user          User         @relation("MembershipUser", fields: [userId], references: [id])
  organization  Organization @relation(fields: [organizationId], references: [id])
  invitedByUser User?        @relation("MembershipInvitedBy", fields: [invitedBy], references: [id])

  @@unique([userId, organizationId])
  @@map("organization_memberships")
}

model Role {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  contextType    AccessContext @map("context_type")
  organizationId String?       @map("organization_id") @db.Uuid
  isSystem       Boolean       @default(false) @map("is_system")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  organization    Organization?   @relation(fields: [organizationId], references: [id])
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id          String        @id @default(uuid()) @db.Uuid
  key         String        @unique
  name        String
  contextType AccessContext @map("context_type")
  module      String
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  roleId         String    @map("role_id") @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  assignedBy     String?   @map("assigned_by") @db.Uuid
  assignedAt     DateTime? @map("assigned_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  user           User          @relation("UserRoleUser", fields: [userId], references: [id])
  role           Role          @relation(fields: [roleId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  assignedByUser User?         @relation("UserRoleAssignedBy", fields: [assignedBy], references: [id])

  @@unique([userId, roleId], map: "user_roles_user_role_platform_unique", where: raw("\"organization_id\" IS NULL"))
  @@unique([userId, roleId, organizationId], map: "user_roles_user_role_org_unique", where: raw("\"organization_id\" IS NOT NULL"))
  @@map("user_roles")
}

model Plan {
  id            String       @id @default(uuid()) @db.Uuid
  name          String
  code          String       @unique
  price         Decimal      @db.Decimal(12, 2)
  currency      String
  interval      PlanInterval @map("interval")
  intervalCount Int          @default(1) @map("interval_count")
  trialDays     Int          @default(0) @map("trial_days")
  maxUsers      Int?         @map("max_users")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  subscriptions               Subscription[]            @relation("SubscriptionPlan")
  pendingSubscriptions        Subscription[]            @relation("SubscriptionPendingPlan")
  subscriptionPlanHistoryFrom SubscriptionPlanHistory[] @relation("SubscriptionPlanHistoryFrom")
  subscriptionPlanHistoryTo   SubscriptionPlanHistory[] @relation("SubscriptionPlanHistoryTo")

  @@map("plans")
}

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  organizationId         String             @map("organization_id") @db.Uuid
  planId                 String             @map("plan_id") @db.Uuid
  status                 SubscriptionStatus
  subscribedAt           DateTime           @map("subscribed_at")
  activatedAt            DateTime?          @map("activated_at")
  canceledAt             DateTime?          @map("canceled_at")
  endedAt                DateTime?          @map("ended_at")
  currentPeriodStart     DateTime?          @map("current_period_start")
  currentPeriodEnd       DateTime?          @map("current_period_end")
  trialStartAt           DateTime?          @map("trial_start_at")
  trialEndAt             DateTime?          @map("trial_end_at")
  pendingPlanId          String?            @map("pending_plan_id") @db.Uuid
  pendingPlanEffectiveAt DateTime?          @map("pending_plan_effective_at")
  billingProvider        String             @default("manual") @map("billing_provider")
  stripeCustomerId       String?            @map("stripe_customer_id")
  stripeSubscriptionId   String?            @map("stripe_subscription_id")
  discountType           DiscountType?      @map("discount_type")
  discountValue          Decimal?           @map("discount_value") @db.Decimal(12, 2)
  discountReason         String?            @map("discount_reason")
  discountStartsAt       DateTime?          @map("discount_starts_at")
  discountEndsAt         DateTime?          @map("discount_ends_at")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  deletedAt              DateTime?          @map("deleted_at")

  organization Organization              @relation(fields: [organizationId], references: [id])
  plan         Plan                      @relation("SubscriptionPlan", fields: [planId], references: [id])
  pendingPlan  Plan?                     @relation("SubscriptionPendingPlan", fields: [pendingPlanId], references: [id])
  planHistory  SubscriptionPlanHistory[]
  invoices     Invoice[]
  transactions Transaction[]

  @@map("subscriptions")
}

model SubscriptionPlanHistory {
  id             String   @id @default(uuid()) @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  fromPlanId     String?  @map("from_plan_id") @db.Uuid
  toPlanId       String   @map("to_plan_id") @db.Uuid
  changeType     String   @map("change_type")
  effectiveAt    DateTime @map("effective_at")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  fromPlan     Plan?        @relation("SubscriptionPlanHistoryFrom", fields: [fromPlanId], references: [id])
  toPlan       Plan         @relation("SubscriptionPlanHistoryTo", fields: [toPlanId], references: [id])

  @@map("subscription_plan_history")
}

model Invoice {
  id                String        @id @default(uuid()) @db.Uuid
  organizationId    String        @map("organization_id") @db.Uuid
  subscriptionId    String?       @map("subscription_id") @db.Uuid
  invoiceNumber     String        @map("invoice_number")
  status            InvoiceStatus
  currency          String
  subtotal          Decimal       @default(0) @db.Decimal(12, 2)
  discountTotal     Decimal       @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal          Decimal       @default(0) @map("tax_total") @db.Decimal(12, 2)
  total             Decimal       @default(0) @db.Decimal(12, 2)
  amountPaid        Decimal       @default(0) @map("amount_paid") @db.Decimal(12, 2)
  amountDue         Decimal       @default(0) @map("amount_due") @db.Decimal(12, 2)
  issueDate         DateTime?     @map("issue_date")
  dueDate           DateTime?     @map("due_date")
  paidAt            DateTime?     @map("paid_at")
  voidedAt          DateTime?     @map("voided_at")
  externalInvoiceId String?       @map("external_invoice_id")
  notes             String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  deletedAt         DateTime?     @map("deleted_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  items        InvoiceItem[]
  transactions Transaction[]

  @@unique([organizationId, invoiceNumber])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  description String
  quantity    Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal  @default(0) @map("unit_price") @db.Decimal(12, 2)
  amount      Decimal  @default(0) @db.Decimal(12, 2)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_items")
}

model Transaction {
  id                    String            @id @default(uuid()) @db.Uuid
  organizationId        String            @map("organization_id") @db.Uuid
  subscriptionId        String?           @map("subscription_id") @db.Uuid
  invoiceId             String?           @map("invoice_id") @db.Uuid
  amount                Decimal           @db.Decimal(12, 2)
  currency              String
  status                TransactionStatus
  paymentMethod         PaymentMethod     @map("payment_method")
  billingProvider       String            @default("manual") @map("billing_provider")
  stripePaymentIntentId String?           @map("stripe_payment_intent_id")
  externalTransactionId String?           @map("external_transaction_id")
  reference             String?
  discountType          DiscountType?     @map("discount_type")
  discountValue         Decimal?          @map("discount_value") @db.Decimal(12, 2)
  initiatedAt           DateTime?         @map("initiated_at")
  paidAt                DateTime?         @map("paid_at")
  failedAt              DateTime?         @map("failed_at")
  refundedAt            DateTime?         @map("refunded_at")
  metadata              Json?
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  deletedAt             DateTime?         @map("deleted_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  invoice      Invoice?      @relation(fields: [invoiceId], references: [id])

  @@map("transactions")
}
