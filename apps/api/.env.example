# Copy to .env and adjust. Requires Postgres (see root docker-compose.yml).
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:7778/starter_db?schema=public
CORS_ALLOWED_ORIGINS='http://localhost:3001,http://localhost:3002,http://localhost:3003'
JWT_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_SESSION_EXPIRES_IN=8h
PASSWORD_RESET_EXPIRES_IN=1h
APP_PUBLIC_URL=http://localhost:3002
REFRESH_COOKIE_NAME=starter_refresh
ADMIN_REFRESH_COOKIE_NAME=starter_admin_refresh
TRUST_PROXY=false
PORT=3000
