{
  "extends": "@repo/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@repo/ui/lib": ["../../packages/ui/src/lib"],
      "@repo/ui/lib/*": ["../../packages/ui/src/lib/*"],
      "@repo/ui/styles": ["../../packages/ui/src/styles"],
      "@repo/ui/styles/*": ["../../packages/ui/src/styles/*"],
      "@repo/web-utils": ["../../packages/web-utils/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "**/*.mts"],
  "exclude": ["node_modules"]
}
